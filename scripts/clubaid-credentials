#!/usr/bin/env bash
# dev-script: targets=local
# Re-hydrate clubaid_upload integration credentials. Wraps platform/scripts/clubaid-credentials.
#
# The real script lives in the platform repo (it delegates auth to platform-session
# and reads ~/code/env/clubaid-credentials.txt), so this wrapper just runs it from
# the platform repo root and forwards your args. It picks its own environment via
# its own --env flag and confirms before production.
#
#   dev scripts run clubaid-credentials --env development --dry-run
#   dev scripts run clubaid-credentials --env production
set -euo pipefail
target="$HOME/code/platform/scripts/clubaid-credentials"
[[ -x "$target" ]] || { echo "ERROR: not found/executable: $target (is the platform repo cloned at ~/code/platform?)" >&2; exit 1; }
cd "$HOME/code/platform"
exec ./scripts/clubaid-credentials "$@"
