/// Acumen application configuration
/// Used by generate-k8s.rb to generate manifests from scala-play-app template
///
/// Load balancer managed via doctl:
///   Name: acumen-lb
///   Certificate: 20210406-2-trueacumen-com-ssl-cert (edfc2ac4-5f15-4d4c-baec-7b4e9516384c)
///   Hostname: api.trueacumen.com
///   Targets: droplets tagged `web-lb-target` (auto-tracks pool replacement)

module acumen

appName = "acumen"
appPort = 9200
webMemory = "1100Mi"
// Pin acumen-job to its proven-working footprint. The scala-play-app template
// default is now sized for platform-job's clubaid pipeline (13000Mi) and would
// be far more than acumen-job needs on its next redeploy.
jobMemory = "5600Mi"
