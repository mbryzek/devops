#!/usr/bin/env ruby

# Run this script from the project root directory
# Deploys SvelteKit apps to Cloudflare Pages
# Supports both @sveltejs/adapter-static (outputs to build/)
# and @sveltejs/adapter-cloudflare (outputs to .svelte-kit/cloudflare)

dir = File.dirname(__FILE__)
load File.join(dir, "../lib/common.rb")

helper = ReleaseHelper.new("sveltekit")

# Check if wrangler is installed
unless system('which wrangler > /dev/null 2>&1')
  puts "Error: wrangler CLI not found"
  puts "Install with: npm install -g wrangler"
  exit 1
end

# Check if logged in
unless system('wrangler whoami > /dev/null 2>&1')
  helper.run "wrangler login"
  exit 1
end

# Verify .env.production exists (required for Vite build-time env vars)
unless File.exist?(".env.production")
  puts "Error: .env.production not found"
  puts "This file is required for production builds (VITE_API_BASE_URL, etc.)"
  exit 1
end

# Clean previous builds
helper.run "rm -rf build .svelte-kit/cloudflare"

tag = Tag.ask
helper.maybe_tag_and_push(tag)

# Write .env.version so the deployed app can serve /_internal_/version
set_version_cmd = File.expand_path("~/code/claude/bin/set-version") +
  " --app #{helper.app} --version #{tag}"
helper.run(set_version_cmd)

# Build the project
helper.run_system("npm run build")

# Detect output directory based on adapter
output_dir = if Dir.exist?("build")
  "build"
elsif Dir.exist?(".svelte-kit/cloudflare")
  ".svelte-kit/cloudflare"
else
  puts "Error: No build output found"
  puts "Expected 'build/' (adapter-static) or '.svelte-kit/cloudflare' (adapter-cloudflare)"
  exit 1
end

puts "Deploying from #{output_dir}"

# Deploy mechanism: Cloudflare Pages vs. Workers.
#
# Most SvelteKit apps here deploy to Cloudflare Pages. The owner app
# (`clubaid`, see SP-A/SP-B of the club-subdomains program) must deploy as a
# *Worker* so it can bind the wildcard route `*.clubaid.co/*` (Pages custom
# domains are not wildcard-capable). The signal is wrangler.toml: a Pages
# project declares `pages_build_output_dir`; a Worker declares `main` (its
# entry) and `routes`. `wrangler deploy` reads wrangler.toml directly, so no
# output_dir argument is passed for the Worker path.
#
# NOTE (SP-A spike sketch — SP-B owns the production version): SP-B will pin
# the exact adapter-cloudflare Worker wrangler.toml (`main` =
# `.svelte-kit/cloudflare/_worker.js`, an `assets` binding to the build dir,
# and the `routes` block) when it scaffolds the new repo. This branch only
# routes the deploy command; it does not yet generate that config.
# Read once; ignore commented-out lines so a `# main = ...` note in a Pages
# wrangler.toml is not misread as a Worker.
toml = File.exist?("wrangler.toml") ? File.read("wrangler.toml") : ""
is_worker = toml.match?(/^\s*(?!#)main\s*=/) &&
  !toml.match?(/^\s*(?!#)pages_build_output_dir\s*=/)

if is_worker
  helper.run_system("wrangler deploy")
else
  helper.run_system("wrangler pages deploy #{output_dir}")
end
