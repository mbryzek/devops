#!/usr/bin/env ruby

require 'fileutils'
require 'io/console'
require 'json'
require 'open3'
require 'uri'

load File.join(File.dirname(__FILE__), '../lib/common.rb')

$LOAD_PATH.unshift(File.expand_path('~/code/claude/lib'))
require 'work/registry'

USAGE = <<~USAGE
  Usage: dev <command> [subcommand] [options]

  Commands:
    login [--email EMAIL]
        Log in as a platform admin (prompts for password).

    logout
        Clear the cached devops session.

    invariants check [--app APP] [--localhost]
        Check invariants across endpoints.

    invariants snoozes [--app APP] [--localhost]
        List active invariant snoozes.

    invariants snooze <name> --app APP --days N --reason "TEXT" [--localhost]
        Snooze an invariant for N days. --app is required.

    invariants unsnooze <name> --app APP [--localhost]
        Remove an invariant snooze. --app is required.

    tasks requeue [--app APP] [--localhost]
        Requeue failed async tasks.

    version [--app APP] [--localhost]
    versions [--localhost]
        Show deployed app version(s) and release timestamp.

    pending [--app APP]
        List apps whose origin/main is ahead of the latest tag (need deploy).

    config check [--app APP]
        Diff live ConfigMap in cluster against env/apps/<app>/env/production.env.
    config rollout [--app APP]
        Apply k8s-secrets and rollout restart workloads (picks up ConfigMap changes).

    browserslist update [--app NAME] [--verbose] [--keep-tmp-dir]
        Shallow-clone every ~/code/* repo with a package.json into
        ~/code/browserslist.<YYYYMMDD>/<name>, run `npx update-browserslist-db@latest`,
        and push changes to main. Use --app NAME to limit to one repo (matched by
        directory name under ~/code). The temp dir is deleted on success unless
        --keep-tmp-dir is passed; it is always kept if any repo fails so output
        can be inspected. Quiet by default; use --verbose to stream full output.

  Common options:
    --app APP       Limit to a single app (acumen, platform)
    --localhost     Hit local development servers instead of production
USAGE

def usage_exit(msg = nil)
  warn msg if msg
  warn USAGE
  exit(msg ? 1 : 0)
end

def parse_common_flags(args)
  app_filter = nil
  use_localhost = false
  rest = []
  i = 0
  while i < args.length
    a = args[i]
    case a
    when "--app"
      app_filter = args[i + 1]
      usage_exit("--app requires a value") if app_filter.nil?
      i += 2
    when "--localhost"
      use_localhost = true
      i += 1
    when "-h", "--help"
      usage_exit
    else
      rest << a
      i += 1
    end
  end
  [rest, app_filter, use_localhost]
end

def resolve_endpoints(app_filter, use_localhost)
  list = ApiClient.endpoints(use_localhost: use_localhost, app_filter: app_filter)
  if list.empty?
    valid = ApiClient::ENDPOINTS.map { |e| e[:app] }.join(", ")
    Util.exit_with_error("Unknown app '#{app_filter}'. Valid apps: #{valid}")
  end
  list
end

def handle_errors
  yield
rescue SessionExpired
  warn "session expired or invalid - run 'dev login'"
  exit 1
rescue ApiError => e
  warn e.message
  exit 1
end

def platform_endpoint(use_localhost)
  ApiClient.endpoints(use_localhost: use_localhost, app_filter: "platform").first
end

# ---------- login / logout ----------

def cmd_login(args)
  email = nil
  use_localhost = false
  i = 0
  while i < args.length
    a = args[i]
    case a
    when "--email"
      email = args[i + 1]
      usage_exit("--email requires a value") if email.nil?
      i += 2
    when "--localhost"
      use_localhost = true
      i += 1
    else
      usage_exit("Unknown argument: #{a}")
    end
  end

  if email.nil? || email.empty?
    print "Email: "
    email = STDIN.gets&.strip
    usage_exit("Email is required") if email.nil? || email.empty?
  end

  print "Password: "
  password = STDIN.noecho(&:gets)&.chomp
  puts ""
  Util.exit_with_error("Password is required") if password.nil? || password.empty?

  endpoint = platform_endpoint(use_localhost)
  begin
    res = ApiClient.request(endpoint, :post, "/tenant/platform/session/logins",
                            body: { email: email, password: password },
                            auth_required: false)
  rescue ApiError => e
    Util.exit_with_error("Login failed: #{e.message}")
  end

  unless res.is_a?(Hash) && res["discriminator"] == "tenant_session"
    Util.exit_with_error("Login failed: unexpected response: #{res.inspect}")
  end

  session = res["session"]
  session_id = session && session["id"]
  Util.exit_with_error("Login response missing session.id: #{res.inspect}") if session_id.nil? || session_id.empty?

  ApiClient.write_session_id(session_id)
  user = res["user"] || {}
  puts "Logged in as #{user['email'] || email}"
end

def cmd_logout(args)
  use_localhost = false
  args.each do |a|
    case a
    when "--localhost" then use_localhost = true
    else usage_exit("Unknown argument: #{a}")
    end
  end

  if ApiClient.session_id.nil?
    puts "No active session"
    return
  end

  endpoint = platform_endpoint(use_localhost)
  begin
    ApiClient.request(endpoint, :delete, "/tenant/platform/session", auth_required: true)
  rescue SessionExpired, ApiError
    # ignore - we'll clear locally anyway
  end
  ApiClient.clear_session_id
  puts "Logged out"
end

# ---------- invariants ----------

def print_invariant_failures(result)
  (result["non_zero"] || []).each do |inv|
    puts "  - #{inv['name']}"
    puts "    Count: #{inv['count']}"
    examples = inv["examples"] || []
    unless examples.empty?
      puts "    Examples:"
      examples.take(3).each { |ex| puts "      * #{ex}" }
      if examples.length > 3
        puts "      ... and #{examples.length - 3} more"
      end
    end
  end

  (result["error"] || []).each do |inv|
    puts "  - #{inv['name']}"
    puts "    Error: #{inv['error'] || 'Unknown error'}"
  end
end

def cmd_invariants_check(args)
  _, app_filter, use_localhost = parse_common_flags(args)
  endpoints = resolve_endpoints(app_filter, use_localhost)

  puts ""
  puts Util.underline("Checking Invariants#{use_localhost ? ' (localhost)' : ''}")
  puts ""

  print "Fetching #{endpoints.map { |e| e[:name] }.join(', ')}..."
  $stdout.flush

  results = endpoints.map do |endpoint|
    Thread.new do
      begin
        data = ApiClient.request(endpoint, :get, "/dev/invariant/checks")
        { endpoint: endpoint, data: data, error: nil }
      rescue SessionExpired => e
        { endpoint: endpoint, data: nil, error: "session expired - run 'dev login'" }
      rescue ApiError => e
        { endpoint: endpoint, data: nil, error: e.message }
      rescue => e
        { endpoint: endpoint, data: nil, error: e.message }
      end
    end
  end.map(&:value)

  puts " done"
  puts ""

  all_passed = true
  results.sort_by { |r| r[:endpoint][:name] }.each do |r|
    endpoint = r[:endpoint]
    if r[:error]
      puts Util.underline("#{endpoint[:name]}: ERROR - #{r[:error]}")
      all_passed = false
    else
      result = r[:data] || {}
      success = result["success"] || []
      non_zero = result["non_zero"] || []
      errors = result["error"] || []
      total_count = success.length + non_zero.length + errors.length
      failure_count = non_zero.length + errors.length

      if failure_count == 0
        puts "#{endpoint[:name]}: #{total_count} invariants passed"
      else
        puts Util.underline("#{endpoint[:name]}: #{failure_count} FAILURES (#{total_count} total)")
        print_invariant_failures(result)
        all_passed = false
      end
    end
    puts ""
  end

  if all_passed
    puts "All invariants passed"
    exit 0
  else
    puts "Some invariants failed"
    exit 1
  end
end

def cmd_invariants_snoozes(args)
  _, app_filter, use_localhost = parse_common_flags(args)
  endpoints = resolve_endpoints(app_filter, use_localhost)

  puts ""
  puts Util.underline("Invariant Snoozes#{use_localhost ? ' (localhost)' : ''}")
  puts ""

  handle_errors do
    endpoints.each do |endpoint|
      snoozes = ApiClient.request(endpoint, :get, "/dev/invariant/snoozes") || []
      puts "#{endpoint[:name]}: #{snoozes.length} active"
      snoozes.each do |s|
        puts "  - #{s['invariant_name']}"
        puts "    Until:   #{s['snoozed_until']}"
        puts "    Reason:  #{s['reason']}"
        puts "    By:      #{s['created_by_user_id']} at #{s['created_at']}"
      end
      puts ""
    end
  end
end

def cmd_invariants_snooze(args)
  rest, app_filter, use_localhost = parse_common_flags(args)
  days = nil
  reason = nil
  positional = []
  i = 0
  while i < rest.length
    a = rest[i]
    case a
    when "--days"
      days = rest[i + 1]
      usage_exit("--days requires a value") if days.nil?
      i += 2
    when "--reason"
      reason = rest[i + 1]
      usage_exit("--reason requires a value") if reason.nil?
      i += 2
    else
      positional << a
      i += 1
    end
  end

  usage_exit("snooze requires an invariant name") if positional.length != 1
  name = positional.first
  usage_exit("--days is required") if days.nil?
  usage_exit("--reason is required") if reason.nil? || reason.empty?

  days_i = Integer(days) rescue nil
  usage_exit("--days must be an integer >= 1") if days_i.nil? || days_i < 1

  if app_filter.nil? || app_filter.empty?
    Util.exit_with_error("--app is required for snooze (mutations must target a single app)")
  end

  endpoints = resolve_endpoints(app_filter, use_localhost)

  handle_errors do
    endpoints.each do |endpoint|
      res = ApiClient.request(endpoint, :post, "/dev/invariant/snoozes",
                              body: { invariant_name: name, days: days_i, reason: reason })
      puts "#{endpoint[:name]}: snoozed #{res['invariant_name']} until #{res['snoozed_until']}"
    end
  end
end

def cmd_invariants_unsnooze(args)
  rest, app_filter, use_localhost = parse_common_flags(args)
  usage_exit("unsnooze requires an invariant name") if rest.length != 1
  name = rest.first
  if app_filter.nil? || app_filter.empty?
    Util.exit_with_error("--app is required for unsnooze (mutations must target a single app)")
  end
  endpoints = resolve_endpoints(app_filter, use_localhost)

  handle_errors do
    endpoints.each do |endpoint|
      ApiClient.request(endpoint, :delete, "/dev/invariant/snoozes/#{URI.encode_www_form_component(name)}")
      puts "#{endpoint[:name]}: removed snooze for #{name}"
    end
  end
end

# ---------- tasks ----------

def cmd_tasks_requeue(args)
  _, app_filter, use_localhost = parse_common_flags(args)
  endpoints = resolve_endpoints(app_filter, use_localhost)

  puts ""
  puts Util.underline("Requeuing Failed Tasks#{use_localhost ? ' (localhost)' : ''}")
  puts ""

  all_ok = true
  endpoints.each do |endpoint|
    begin
      res = ApiClient.request(endpoint, :post, "/dev/task/requeues", body: {})
      count = res && res["requeued"]
      puts "  #{endpoint[:name]}: #{count} tasks requeued"
    rescue SessionExpired
      puts "  #{endpoint[:name]}: ERROR - session expired or invalid - run 'dev login'"
      all_ok = false
    rescue ApiError => e
      puts "  #{endpoint[:name]}: ERROR - #{e.message}"
      all_ok = false
    end
  end

  puts ""
  exit 1 unless all_ok
end

# ---------- versions ----------

def fetch_version(url)
  uri = URI.parse("#{url}/_internal_/version")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = (uri.scheme == "https")
  http.open_timeout = 5
  http.read_timeout = 10
  res = http.request(Net::HTTP::Get.new(uri.request_uri))
  return { error: "HTTP #{res.code}" } unless res.code.to_i.between?(200, 299)
  return { error: "empty body" } if res.body.nil? || res.body.empty?
  JSON.parse(res.body)
rescue => e
  { error: e.message }
end

# For docker_k8s apps with no public ingress, read the live image tag straight
# from the cluster. The image tag is what's *actually* running and avoids
# requiring an HTTP /_internal_/version on internal-only services.
def fetch_k8s_version(app)
  ns = app.docker_k8s.namespace
  target = app.docker_k8s.rollout_target  # e.g. "statefulset/court-reserve-workers"
  image, status = Open3.capture2(
    "kubectl", "-n", ns, "get", target,
    "-o", "jsonpath={.spec.template.spec.containers[0].image}"
  )
  return { error: "kubectl get #{target}: failed" } unless status.success?
  image = image.strip
  return { error: "kubectl returned empty image" } if image.empty?
  # Tag is everything after the LAST ':' in the final path segment — this
  # avoids treating a registry port (host:5000/...) as the tag.
  last_segment = image.split("/").last
  tag = last_segment.include?(":") ? last_segment.split(":", 2)[1] : nil
  return { error: "image has no tag: #{image}" } if tag.nil? || tag.empty?

  # released_at = the current pod's start time. This approximates "when this
  # version went live" but advances on any pod restart (OOM kill, liveness
  # failure) — not strictly the deploy time. Good enough for the versions
  # command; we'd need a deploy annotation for a true deploy timestamp.
  started_at, _ = Open3.capture2(
    "kubectl", "-n", ns, "get", "pod",
    "-l", "app=#{app.name}",
    "-o", "jsonpath={.items[0].status.startTime}"
  )
  released_at = started_at.strip
  released_at = nil if released_at.empty?

  { "version" => tag, "released_at" => released_at }
rescue => e
  { error: e.message }
end

def fetch_app_version(registry, app)
  url = registry.prod_url(app)
  return fetch_version(url) if url
  return fetch_k8s_version(app) if app.docker_k8s
  { error: "no prod url or docker_k8s config" }
end

def cmd_versions(args)
  _, app_filter, _ = parse_common_flags(args)

  registry = Work::Registry.load
  apps = registry.deployable.sort_by(&:name)
  apps = apps.select { |a| a.name == app_filter } if app_filter

  if apps.empty?
    valid = registry.deployable.map(&:name).sort.join(", ")
    Util.exit_with_error("Unknown app '#{app_filter}'. Valid apps: #{valid}")
  end

  rows = apps.map do |app|
    Thread.new { [app.name, fetch_app_version(registry, app)] }
  end.map(&:value)

  name_w = rows.map { |n, _| n.length }.max
  ver_w  = rows.map { |_, d| (d["version"] || "").to_s.length }.max
  rows.each do |name, d|
    if d[:error]
      puts "#{name.ljust(name_w)}  ERROR - #{d[:error]}"
    else
      ver = (d["version"] || "(unknown)").ljust(ver_w)
      puts "#{name.ljust(name_w)}  #{ver}  released #{d['released_at'] || '(unknown)'}"
    end
  end
end

# ---------- pending deploys ----------

def pending_for(app)
  dir = File.expand_path("~/code/#{app.name}")
  return { error: "no checkout at #{dir}" } unless File.directory?(File.join(dir, ".git"))

  fetch_err = `git -C #{dir} fetch -q origin 2>&1`
  return { error: "fetch failed: #{fetch_err.strip}" } unless $?.success?

  tag = `cd #{dir} && sem-info tag latest 2>/dev/null`.strip
  return { error: "no tag" } if tag.empty? || tag == "0.0.0"

  ref = `git -C #{dir} rev-parse --verify --quiet origin/main`.strip
  ref = `git -C #{dir} rev-parse --verify --quiet origin/master`.strip if ref.empty?
  return { error: "no origin/main" } if ref.empty?

  count = `git -C #{dir} rev-list --count #{tag}..#{ref}`.strip.to_i
  last = `git -C #{dir} log -1 --format=%h\\ %s #{ref}`.strip
  { tag: tag, ahead: count, last: last }
end

def cmd_pending(args)
  _, app_filter, _ = parse_common_flags(args)

  registry = Work::Registry.load
  apps = registry.deployable.sort_by(&:name)
  apps = apps.select { |a| a.name == app_filter } if app_filter
  if apps.empty?
    valid = registry.deployable.map(&:name).sort.join(", ")
    Util.exit_with_error("Unknown app '#{app_filter}'. Valid apps: #{valid}")
  end

  rows = apps.map do |app|
    Thread.new { [app.name, pending_for(app)] }
  end.map(&:value)

  pending = rows.select { |_, d| d[:error].nil? && d[:ahead] > 0 }
  errors  = rows.select { |_, d| d[:error] }

  if pending.empty?
    puts "All apps up to date"
  else
    name_w = pending.map { |n, _| n.length }.max
    tag_w  = pending.map { |_, d| d[:tag].length }.max
    pending.each do |name, d|
      puts "#{name.ljust(name_w)}  #{d[:tag].ljust(tag_w)}  +#{d[:ahead]}  #{d[:last]}"
    end
  end

  unless errors.empty?
    puts ""
    errors.each { |name, d| puts "#{name}: #{d[:error]}" }
  end
end

# ---------- config drift ----------

K8S_NAMESPACE = 'bryzek-production'

def k8s_apps(app_filter)
  registry = Work::Registry.load
  apps = registry.deployable.map(&:name).sort
  apps = apps.select { |n| File.exist?(File.expand_path("~/code/env/apps/#{n}/env/production.env")) }
  apps = apps.select { |n| n == app_filter } if app_filter
  Util.exit_with_error("No apps with production.env match '#{app_filter}'") if apps.empty?
  apps
end

def expected_config_vars(app)
  vars = JSON.parse(EnvironmentVariables.load(app, 'production').serialize('json'))
  vars.select { |k, _| k.start_with?('CONF_') }
end

def live_config_vars(app)
  out, status = Open3.capture2("kubectl", "get", "configmap", "#{app}-config",
                                "-n", K8S_NAMESPACE, "-o", "json")
  return nil unless status.success?
  JSON.parse(out)["data"] || {}
end

def diff_config(app)
  expected = expected_config_vars(app)
  live = live_config_vars(app)
  return { error: "ConfigMap #{app}-config not found" } if live.nil?

  missing  = expected.keys - live.keys
  extra    = live.keys - expected.keys
  changed  = (expected.keys & live.keys).select { |k| expected[k] != live[k] }
  { missing: missing, extra: extra, changed: changed, expected: expected, live: live }
end

def cmd_config_check(args)
  require 'open3'
  _, app_filter, _ = parse_common_flags(args)
  apps = k8s_apps(app_filter)

  any_drift = false
  apps.each do |app|
    d = diff_config(app)
    if d[:error]
      puts "#{app}: ERROR - #{d[:error]}"
      any_drift = true
      next
    end
    drift_count = d[:missing].length + d[:extra].length + d[:changed].length
    if drift_count == 0
      puts "#{app}: in sync (#{d[:expected].size} keys)"
    else
      any_drift = true
      puts "#{app}: DRIFT (#{drift_count} differences)"
      d[:missing].sort.each { |k| puts "  + #{k} (in env, not in cluster)" }
      d[:extra].sort.each   { |k| puts "  - #{k} (in cluster, not in env)" }
      d[:changed].sort.each do |k|
        puts "  ~ #{k}"
        puts "      env:     #{d[:expected][k].inspect}"
        puts "      cluster: #{d[:live][k].inspect}"
      end
    end
  end
  exit(any_drift ? 1 : 0)
end

def cmd_config_rollout(args)
  require 'open3'
  _, app_filter, _ = parse_common_flags(args)
  apps = k8s_apps(app_filter)
  bin_dir = File.dirname(__FILE__)

  apps.each do |app|
    puts ""
    puts Util.underline("#{app}: apply k8s-secrets")
    Util.run("#{File.join(bin_dir, 'k8s-secrets')} --app #{app}")

    puts ""
    puts Util.underline("#{app}: rollout restart")
    Util.run("kubectl rollout restart statefulset,deployment -l app=#{app} -n #{K8S_NAMESPACE}")
    Util.run("kubectl rollout status statefulset,deployment -l app=#{app} -n #{K8S_NAMESPACE} --timeout=5m")
  end
end

# ---------- browserslist ----------

def git_current_branch(path)
  out, status = Open3.capture2("git", "-C", path, "symbolic-ref", "--short", "HEAD")
  status.success? ? out.strip : nil
end

def git_clean?(path)
  out, status = Open3.capture2("git", "-C", path, "status", "--porcelain")
  status.success? && out.strip.empty?
end

def run_step(cmd, path, verbose, captured_log)
  if verbose
    ok = system(*cmd, chdir: path)
    [ok, nil]
  else
    out, status = Open3.capture2e(*cmd, chdir: path)
    captured_log << out
    [status.success?, out]
  end
end

def report_repo_line(name, status, detail, verbose)
  return if verbose
  suffix = detail ? "#{status}: #{detail}" : status
  puts "  #{name} [#{suffix}]"
end

def git_origin_url(path)
  out, status = Open3.capture2("git", "-C", path, "config", "--get", "remote.origin.url")
  status.success? ? out.strip : nil
end

def cmd_browserslist_update(args)
  verbose = false
  keep_tmp = false
  app_filter = nil
  i = 0
  rest = []
  while i < args.length
    a = args[i]
    case a
    when "--verbose", "-v" then verbose = true; i += 1
    when "--keep-tmp-dir"  then keep_tmp = true; i += 1
    when "--app"
      app_filter = args[i + 1]
      usage_exit("--app requires a value") if app_filter.nil?
      i += 2
    else
      rest << a
      i += 1
    end
  end
  usage_exit("browserslist update takes no positional arguments") unless rest.empty?

  code_root = File.expand_path("~/code")
  source_repos = Dir.children(code_root)
    .map { |name| File.join(code_root, name) }
    .select { |path| File.directory?(path) && File.exist?(File.join(path, "package.json")) && File.directory?(File.join(path, ".git")) }
    .sort

  if app_filter
    source_repos = source_repos.select { |p| File.basename(p) == app_filter }
    if source_repos.empty?
      Util.exit_with_error("No repo named '#{app_filter}' with package.json + .git under #{code_root}")
    end
  end

  if source_repos.empty?
    puts "No repos with package.json + .git under #{code_root}"
    return
  end

  date = Time.now.strftime("%Y%m%d")
  workdir = File.join(code_root, "browserslist.#{date}")
  FileUtils.mkdir_p(workdir) unless File.directory?(workdir)

  puts "Working in #{workdir}"
  puts "Processing #{source_repos.length} repo(s)..."
  puts ""

  failures = []
  updated = []
  no_changes = []
  no_remote = []
  logs = {}

  source_repos.each do |src_path|
    name = File.basename(src_path)
    puts Util.underline(name) if verbose

    origin = git_origin_url(src_path)
    if origin.nil? || origin.empty?
      no_remote << name
      report_repo_line(name, "skipped", "no remote", verbose)
      puts "" if verbose
      next
    end

    clone_path = File.join(workdir, name)
    captured = +""

    if File.directory?(clone_path)
      FileUtils.rm_rf(clone_path)
    end

    ok, _ = run_step(["git", "clone", "--depth=1", "--quiet", origin, clone_path], workdir, verbose, captured)
    unless ok
      failures << "#{name} (clone failed)"
      logs[name] = captured unless verbose
      report_repo_line(name, "FAIL", "git clone", verbose)
      puts "" if verbose
      next
    end

    ok, _ = run_step(["npx", "--yes", "update-browserslist-db@latest"], clone_path, verbose, captured)
    unless ok
      failures << name
      logs[name] = captured unless verbose
      report_repo_line(name, "FAIL", "update-browserslist-db", verbose)
      puts "" if verbose
      next
    end

    if git_clean?(clone_path)
      no_changes << name
      report_repo_line(name, "no changes", nil, verbose)
      puts "" if verbose
      next
    end

    msg = "Update caniuse-lite via update-browserslist-db"
    ok, _ = run_step(["git", "-C", clone_path, "commit", "-am", msg], clone_path, verbose, captured)
    unless ok
      failures << "#{name} (commit failed)"
      logs[name] = captured unless verbose
      report_repo_line(name, "FAIL", "git commit", verbose)
      puts "" if verbose
      next
    end

    ok, _ = run_step(["git", "-C", clone_path, "push", "origin", "HEAD:main"], clone_path, verbose, captured)
    unless ok
      failures << "#{name} (push failed)"
      logs[name] = captured unless verbose
      report_repo_line(name, "FAIL", "git push", verbose)
      puts "" if verbose
      next
    end

    updated << name
    report_repo_line(name, "done", nil, verbose)
    puts "" if verbose
  end

  puts ""
  puts Util.underline("Summary")
  puts "  updated + pushed: #{updated.empty? ? '(none)' : updated.join(', ')}"
  puts "  no changes:       #{no_changes.join(', ')}" unless no_changes.empty?
  puts "  no remote:        #{no_remote.join(', ')}" unless no_remote.empty?
  puts "  failed:           #{failures.join(', ')}" unless failures.empty?

  unless verbose || logs.empty?
    puts ""
    puts "Re-run with --verbose for full output. Captured failure output:"
    logs.each do |name, out|
      puts ""
      puts Util.underline(name)
      puts out
    end
  end

  if failures.empty? && !keep_tmp
    FileUtils.rm_rf(workdir)
    puts ""
    puts "Removed #{workdir}"
  elsif !failures.empty?
    puts ""
    puts "Kept #{workdir} for inspection (failures present)"
  end

  exit 1 unless failures.empty?
end

# ---------- dispatch ----------

argv = ARGV.dup
usage_exit if argv.empty?
usage_exit if %w[-h --help help].include?(argv.first)

command = argv.shift
case command
when "login"
  cmd_login(argv)
when "logout"
  cmd_logout(argv)
when "invariants"
  sub = argv.shift
  case sub
  when "check"     then cmd_invariants_check(argv)
  when "snoozes"   then cmd_invariants_snoozes(argv)
  when "snooze"    then cmd_invariants_snooze(argv)
  when "unsnooze"  then cmd_invariants_unsnooze(argv)
  when nil         then usage_exit("invariants requires a subcommand")
  else                  usage_exit("Unknown invariants subcommand: #{sub}")
  end
when "version", "versions"
  cmd_versions(argv)
when "pending"
  cmd_pending(argv)
when "config"
  sub = argv.shift
  case sub
  when "check"   then cmd_config_check(argv)
  when "rollout" then cmd_config_rollout(argv)
  when nil       then usage_exit("config requires a subcommand")
  else                usage_exit("Unknown config subcommand: #{sub}")
  end
when "tasks"
  sub = argv.shift
  case sub
  when "requeue" then cmd_tasks_requeue(argv)
  when nil       then usage_exit("tasks requires a subcommand")
  else                usage_exit("Unknown tasks subcommand: #{sub}")
  end
when "browserslist"
  sub = argv.shift
  case sub
  when "update" then cmd_browserslist_update(argv)
  when nil      then usage_exit("browserslist requires a subcommand")
  else               usage_exit("Unknown browserslist subcommand: #{sub}")
  end
else
  usage_exit("Unknown command: #{command}")
end
