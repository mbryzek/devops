#!/usr/bin/env ruby
# frozen_string_literal: true

# Loads a filtered, PII-obfuscated subset of a PostgreSQL dump into a target DB.
#
# Approach (see db-filter/<db>.yml for the allow-list policy):
#   1. Load the schema in full from the dump — every table, empty.
#   2. Load ONLY the allow-listed tables, each filtered by its predicate, in
#      foreign-key dependency order, with FK constraints ENFORCED.
#
# Because FKs stay enforced, the allow-list must be FK-closed: a violation during
# load names exactly the table to add to the policy. Tables not listed stay empty,
# which is safe — nothing loaded references them.
#
# Usage:
#   db-filter-dump --db platformdb --clubs bounce          # save clubs for platformdb
#   db-filter-dump --db platformdb --input dump.sql        # load filtered subset
#   db-filter-dump --db platformdb --list-clubs
#   db-filter-dump --db platformdb --clear-clubs

require 'digest'
require 'fileutils'
require 'optparse'
require 'set'
require 'yaml'

CONFIG_DIR = File.expand_path('~/.platform')                 # per-developer club selection
POLICY_DIR = File.expand_path('../db-filter', __dir__)       # versioned allow-list policy
COPY_END   = "\\."                                           # PostgreSQL COPY terminator line

def config_file(dbname)
  File.join(CONFIG_DIR, "db-filter-dump.#{dbname}.yml")
end

def policy_file(dbname)
  File.join(POLICY_DIR, "#{dbname}.yml")
end

# ─── PII obfuscation ──────────────────────────────────────────────────────────

def h8(val)
  Digest::MD5.hexdigest(val.to_s)[0, 8]
end

def obfuscate(type, val)
  return val if val.nil? || val == '\N'
  case type
  # Hash on downcase so email and lower_email always agree: lower(obfuscated_email) == obfuscated_lower_email
  when :email, :lower_email then "dev_#{h8(val.downcase)}@example.com"
  when :name     then "Dev#{h8(val).upcase[0, 6]}"
  # Produce a valid all-digit US phone number; integer modulo keeps it numeric.
  when :phone    then "+15550#{(h8(val).to_i(16) % 1_000_000).to_s.rjust(6, '0')}"
  when :address  then "123 Dev Street"
  when :city     then "Devtown"
  when :state    then "CA"
  when :zip      then "00000"
  when :pin      then "0000"
  when :message  then "[redacted]"
  when :generic  then h8(val)
  else val
  end
end

# Columns to obfuscate per table: column_name => obfuscation_type. Only applied to
# tables that are actually loaded, so unlisted tables here are simply inert.
PII = {
  'court_reserve.members' => {
    'first_name' => :name, 'last_name' => :name, 'full_name' => :name,
    'email'      => :email, 'phone' => :phone, 'username' => :email,
    'address'    => :address, 'city' => :city, 'state' => :state,
    'zip_code'   => :zip, 'pin_code' => :pin,
    'family'     => :generic,
    'how_did_you_hear_about_us' => :generic,
    'referrals'  => :generic,
  },
  'court_reserve.event_registrations' => {
    'member_first_name' => :name, 'member_last_name' => :name,
    'member_full_name'  => :name, 'member_email'     => :email,
    'member_phone'      => :phone,
    'primary_first_name' => :name, 'primary_last_name' => :name,
    'primary_email'      => :email, 'primary_address'  => :address,
    'primary_city'       => :city,  'primary_state'    => :state,
    'primary_zip_code'   => :zip,
    'how_did_you_hear_about_us' => :generic,
    'referrals'          => :generic,
  },
  'court_reserve.reservations' => {
    'created_by' => :name,
  },
  'court_reserve.sales_transactions' => {
    'member_name' => :name,
  },
  'court_reserve.transactions' => {
    'member_name' => :name, 'member_display_name' => :name,
  },
  'court_reserve.audit_events' => {
    'action_by'    => :name,
    'subject_name' => :name,
    'description'  => :message,
  },
  'court_reserve.families' => {
    'name' => :name, # family surname
  },
  'court_reserve.guest_member_numbers' => {
    'raw_value' => :generic, # raw guest identifier (may be a name/phone)
  },
  'clubaid.ai_messages' => {
    # AI Explorer renders sampled member rows into the message context, so these
    # free-text fields can embed member names/emails — redact them wholesale.
    'content'                => :message,
    'rendered_system_prompt' => :message,
    'rendered_context'       => :message,
  },
}.freeze

# ─── Dump parsing ─────────────────────────────────────────────────────────────

def parse_copy_header(line)
  m = line.match(/\ACOPY (\S+) \(([^)]+)\) FROM stdin;\z/)
  return nil unless m
  [m[1], m[2].split(', ').map { |c| c.delete('"') }]
end

# Single pass over the dump: load the schema (everything except COPY data) into the
# target DB, and collect (a) each COPY block's byte offset + columns, (b) the FK graph
# (referencing table => referenced tables) for load ordering, (c) the club parent tree.
def load_schema_and_index(input_path, dbname)
  blocks      = {}                               # table => { cols:, offset: }
  fk_refs     = Hash.new { |h, k| h[k] = [] }    # table => [referenced table, ...]
  club_parent = {}                               # club id => parent id (nil if root)

  cur_alter = nil
  in_copy   = false
  clubs_mode = false
  clubs_id_idx = nil
  clubs_par_idx = nil
  pos = 0

  run_psql(dbname, 'schema load') do |psql|
    File.open(input_path, 'r', encoding: 'binary') do |f|
      while (raw = f.gets)
        pos += raw.bytesize
        line = raw.chomp

        if !in_copy && line.start_with?('COPY ') && line.end_with?('FROM stdin;')
          parsed = parse_copy_header(line)
          if parsed
            table, cols = parsed
            blocks[table] = { cols: cols, offset: pos } # pos == start of first data row
            in_copy = true
            clubs_mode = (table == 'clubaid.clubs')
            if clubs_mode
              clubs_id_idx  = cols.index('id')
              clubs_par_idx = cols.index('parent_id')
            end
          end
          next # COPY blocks are dropped from the schema load
        end

        if in_copy
          if line == COPY_END
            in_copy = false
            clubs_mode = false
          elsif clubs_mode && clubs_id_idx && clubs_par_idx
            fields = line.split("\t")
            club_parent[fields[clubs_id_idx]] = fields[clubs_par_idx] == '\N' ? nil : fields[clubs_par_idx]
          end
          next
        end

        # Non-COPY line: part of the schema. Emit to psql and harvest FK edges.
        psql.write(raw)
        if (m = line.match(/\AALTER TABLE (?:ONLY )?(\S+)/))
          cur_alter = m[1]
        end
        if cur_alter && (m = line.match(/ADD CONSTRAINT \S+ FOREIGN KEY \([^)]+\) REFERENCES (\S+?)\(/))
          fk_refs[cur_alter] << m[1]
        end
      end
    end
  end

  [blocks, fk_refs, club_parent]
end

def expand_club_ids(requested, club_parent)
  children = Hash.new { |h, k| h[k] = [] }
  club_parent.each { |id, par| children[par] << id if par }

  result = Set.new
  queue  = requested.to_a.dup
  until queue.empty?
    id = queue.shift
    next if result.include?(id)
    result << id
    queue.concat(children[id])
  end
  result
end

# Topological order (referenced tables first) over the listed tables, using the FK graph.
# Self-references and FKs to unlisted tables are ignored; cycles are broken best-effort.
def topo_order(listed, fk_refs)
  order = []
  state = {}
  visit = lambda do |t|
    return if state[t] == :done
    return if state[t] == :open # cycle — break here
    state[t] = :open
    (fk_refs[t] || []).each { |ref| visit.call(ref) if listed.include?(ref) && ref != t }
    state[t] = :done
    order << t
  end
  listed.each { |t| visit.call(t) }
  order
end

# ─── Predicates ───────────────────────────────────────────────────────────────

# A policy entry is either a predicate string or a hash { where:, blank: }. Normalize to
# { where: <predicate string>, blank: [columns to set NULL] }. (The key is `blank`, not
# `null`, because a bare `null:` in YAML parses to the nil key rather than the string.)
def normalize_entry(spec)
  if spec.is_a?(Hash)
    { where: (spec['where'] || 'all').to_s, blank: Array(spec['blank']).map(&:to_s) }
  else
    { where: spec.to_s, blank: [] }
  end
end

def parse_predicate(table, spec)
  case spec.strip
  when 'all'
    { kind: :all }
  when /\A(\w+)\s+in\s+:clubs\z/
    { kind: :club, col: Regexp.last_match(1) }
  when /\A(\w+)\s+in\s+(\S+)\.(\w+)\z/
    { kind: :fk, col: Regexp.last_match(1), ref_table: Regexp.last_match(2), ref_col: Regexp.last_match(3) }
  when /\A(\w+)\s*=\s*(.+)\z/
    { kind: :eq, col: Regexp.last_match(1), value: Regexp.last_match(2).strip }
  else
    abort "Invalid predicate for #{table}: #{spec.inspect}"
  end
end

# ─── psql helpers ─────────────────────────────────────────────────────────────

def psql_argv(dbname, *extra)
  ['psql', '--set=ON_ERROR_STOP=on', '-U', 'api', *extra, dbname]
end

def run_psql(dbname, what)
  IO.popen(psql_argv(dbname, '-q'), 'w') do |psql|
    yield psql
  rescue Errno::EPIPE
    # psql exited early (ON_ERROR_STOP) — fall through to the exit-status check below,
    # which raises with a clear message instead of the raw broken-pipe error.
  end
  raise "psql failed during #{what} (exit #{$?.exitstatus})" unless $?.success?
end

def query_values(dbname, table, col)
  out = IO.popen(psql_argv(dbname, '-t', '-A', '-c', "SELECT \"#{col}\" FROM #{table}"), &:read)
  raise "psql query failed on #{table}.#{col} (exit #{$?.exitstatus})" unless $?.success?
  out.split("\n").to_set
end

# Column index for a filter column; fail loudly rather than silently loading every row
# (a nil index would make the `if filter_idx` guard skip filtering entirely).
def column_index!(table, cols, col)
  cols.index(col) or abort "Column #{col.inspect} not found in #{table} — check db-filter policy. Columns: #{cols.join(', ')}"
end

# Map this table's PII columns to their indices, warning loudly about any column the
# dump doesn't have (so plaintext is never silently shipped).
def pii_indices(table, cols)
  return {} unless PII.key?(table)
  PII[table].each_with_object({}) do |(col, type), acc|
    idx = cols.index(col)
    if idx.nil?
      warn "WARNING: PII column #{col.inspect} not found in #{table} — NOT obfuscated"
    else
      acc[idx] = type
    end
  end
end

# Build a row-filter for a predicate: returns [column_index, keep?(value) lambda].
# A nil column_index means "keep every row".
def row_filter(table, cols, pred, dbname, expanded)
  case pred[:kind]
  when :all
    [nil, nil]
  when :club
    set = expanded
    [column_index!(table, cols, pred[:col]), ->(v) { set.include?(v) }]
  when :fk
    set = query_values(dbname, pred[:ref_table], pred[:ref_col])
    [column_index!(table, cols, pred[:col]), ->(v) { set.include?(v) }]
  when :eq
    val = pred[:value]
    [column_index!(table, cols, pred[:col]), ->(v) { v == val }]
  end
end

# Stream one COPY block from the dump (seeking to its offset), filter, blank `blank_cols`,
# obfuscate PII, and COPY the surviving rows into the target DB.
def load_table(input_path, dbname, table, block, pred, expanded, blank_cols)
  cols = block[:cols]
  pii  = pii_indices(table, cols)
  blank_idx = blank_cols.map { |c| column_index!(table, cols, c) }
  filter_idx, keep = row_filter(table, cols, pred, dbname, expanded)
  rewrite = !pii.empty? || !blank_idx.empty?

  kept = 0
  run_psql(dbname, "load #{table}") do |psql|
    psql.puts "COPY #{table} (#{cols.map { |c| "\"#{c}\"" }.join(', ')}) FROM stdin;"
    File.open(input_path, 'r', encoding: 'binary') do |f|
      f.seek(block[:offset])
      while (raw = f.gets)
        line = raw.chomp
        break if line == COPY_END

        if filter_idx
          next unless keep.call(line.split("\t", -1)[filter_idx])
        end

        if rewrite
          fields = line.split("\t", -1)
          blank_idx.each { |i| fields[i] = '\N' }
          pii.each { |i, t| fields[i] = obfuscate(t, fields[i]) }
          line = fields.join("\t")
        end

        psql.puts line
        kept += 1
      end
    end
    psql.puts COPY_END
  end
  kept
end

# ─── Config ───────────────────────────────────────────────────────────────────

def load_clubs_config(cfg_file)
  return {} unless File.exist?(cfg_file)
  YAML.safe_load(File.read(cfg_file)) || {}
end

def save_clubs_config(cfg_file, cfg)
  FileUtils.mkdir_p(CONFIG_DIR)
  File.write(cfg_file, YAML.dump(cfg))
end

def load_policy(dbname)
  pf = policy_file(dbname)
  abort "No allow-list policy for #{dbname} (expected #{pf})." unless File.exist?(pf)
  policy = YAML.safe_load(File.read(pf)) || {}
  tables = policy['tables'] || {}
  abort "Policy #{pf} has no tables." if tables.empty?
  tables
end

# ─── CLI ──────────────────────────────────────────────────────────────────────

def main
  options = {}
  OptionParser.new do |o|
    o.banner = 'Usage: db-filter-dump --db DBNAME [--input FILE] [--clubs id1,id2] [--list-clubs] [--clear-clubs]'
    o.on('--db DBNAME',   'Database name (selects policy db-filter/<db>.yml and clubs config)') { |v| options[:db] = v }
    o.on('--input FILE',  'Path to the SQL dump file to load')                                  { |v| options[:input] = v }
    o.on('--clubs IDS',   'Comma-separated club IDs; saved for this database')                  { |v| options[:clubs] = v.split(',').map(&:strip).reject(&:empty?) }
    o.on('--clear-clubs', 'Clear the saved club list for this database')                        { options[:clear_clubs] = true }
    o.on('--list-clubs',  'Print the saved club list for this database and exit')               { options[:list_clubs] = true }
  end.parse!

  if options[:db].nil? || options[:db].empty?
    abort 'Error: --db DBNAME is required (e.g. --db platformdb).'
  end

  cfg_file = config_file(options[:db])
  cfg      = load_clubs_config(cfg_file)

  if options[:clear_clubs]
    cfg.delete('clubs')
    save_clubs_config(cfg_file, cfg)
    warn "Cleared saved club list from #{cfg_file}."
    exit
  end

  if options[:list_clubs]
    clubs = cfg['clubs'] || []
    if clubs.empty?
      warn "No clubs saved for #{options[:db]}. Use --clubs id1,id2 to set them."
    else
      warn "Saved clubs for #{options[:db]} (#{clubs.size}):"
      clubs.each { |c| warn "  #{c}" }
    end
    exit
  end

  if options[:clubs]
    cfg['clubs'] = options[:clubs]
    save_clubs_config(cfg_file, cfg)
    warn "Saved #{options[:clubs].size} club(s) to #{cfg_file}."
    exit 0 unless options[:input] # save-only invocation is complete
  end

  requested_clubs = Set.new(cfg['clubs'] || [])
  if requested_clubs.empty?
    abort "No clubs configured for #{options[:db]}. Use --clubs id1,id2."
  end

  input_file = options[:input]
  if input_file.nil? || !File.exist?(input_file)
    abort 'Error: --input FILE is required and must exist.'
  end

  tables = load_policy(options[:db])

  warn "Loading schema and indexing dump..."
  blocks, fk_refs, club_parent = load_schema_and_index(input_file, options[:db])

  expanded = expand_club_ids(requested_clubs, club_parent)
  warn "Clubs: #{requested_clubs.size} requested -> #{expanded.size} after child expansion"

  missing = tables.keys.reject { |t| blocks.key?(t) }
  warn "WARNING: policy lists tables absent from the dump: #{missing.join(', ')}" unless missing.empty?

  order = topo_order(tables.keys.select { |t| blocks.key?(t) }, fk_refs)

  order.each do |table|
    entry = normalize_entry(tables[table])
    pred  = parse_predicate(table, entry[:where])
    n = load_table(input_file, options[:db], table, blocks[table], pred, expanded, entry[:blank])
    warn format('  %-45s %8d rows', table, n)
  end

  warn "Done."
end

main if __FILE__ == $PROGRAM_NAME
