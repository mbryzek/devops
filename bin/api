#!/usr/bin/env ruby

# Unified CLI for API Builder batch operations.
#
# Usage:
#   api                             # auto-detect: upload (if specs found) + codegen
#   api --profile localhost         # same, with profile
#   api upload                      # upload only
#   api codegen                     # codegen only
#   api upload codegen              # upload then codegen
#   api --profile localhost upload codegen  # with profile

load File.join(File.dirname(__FILE__), '../lib/common.rb')

VALID_OPERATIONS = %w[upload codegen].freeze

USAGE = <<~TEXT
  Usage: api [--profile PROFILE] [--app APP ...] [--group GROUP] [<operation> ...]
         api [--profile PROFILE] init [--language typescript] [--language scala]
         api [--profile PROFILE] validate <file>

  Commands:
    init [options]    Create an anonymous org and token, write to ~/.apibuilder/config.
                      Use --language to also create a local .api/config with default
                      code generators. Can be repeated for multiple languages.
    validate <file>   Validate an api.json spec file via server-side validation

  Operations: #{VALID_OPERATIONS.join(', ')}

  When no operations are specified, codegen is always included and upload is
  included automatically if any spec files referenced in .api/config exist locally.

  Options:
    --app APP      Process only the specified application(s). Can be repeated.
    --group GROUP  Process only blocks with the specified group.

  Examples:
    api init                                    # create anonymous org + token
    api init --language typescript              # + create .api/config for TypeScript
    api init --language scala                   # + create .api/config for Scala
    api init --language typescript --language scala  # + create .api/config for both
    api validate spec/myapp.json    # validate a spec file
    api                             # auto-detect operations
    api --profile localhost         # auto-detect with profile
    api upload                      # upload only
    api codegen                     # codegen only
    api upload codegen              # upload then codegen
    api --app platform upload codegen
    api --group dao upload codegen
TEXT

def parse_args(argv)
  profile = nil
  operations = []
  apps = []
  group = nil
  args = argv.dup

  while arg = args.shift
    case arg
    when "--profile"
      profile = args.shift
      Util.exit_with_error("--profile requires a value") if profile.nil?
    when "--app"
      app = args.shift
      Util.exit_with_error("--app requires a value") if app.nil?
      apps << app unless apps.include?(app)
    when "--group"
      group = args.shift
      Util.exit_with_error("--group requires a value") if group.nil?
    when "-h", "--help"
      puts USAGE
      exit 0
    else
      if VALID_OPERATIONS.include?(arg)
        operations << arg unless operations.include?(arg)
      else
        Util.exit_with_error("Unknown argument: #{arg}\n\n#{USAGE}")
      end
    end
  end

  { profile: profile, operations: operations, apps: apps.empty? ? nil : apps, group: group }
end

def build_batch_form(config, org, operations, app_filter, group_filter)

  blocks = config.blocks_for_org(org)
  if group_filter
    blocks = blocks.select { |b| b.group == group_filter }
  end

  # Collect unique applications across all blocks, merging generators
  app_data = {}  # application_key => { file_path:, generators: [] }

  blocks.each do |block|
    block.applications.each do |app|
      next if app_filter && !app_filter.include?(app.key)

      app_data[app.key] ||= { file_path: app.file_path, generators: [] }

      block.generators.each do |gen|
        batch_gen = { "generator_key" => gen.key }
        if !block.attributes.empty?
          batch_gen["attributes"] = block.attributes
        end
        app_data[app.key][:generators] << batch_gen
      end
    end
  end

  applications = app_data.map do |app_key, data|
    entry = { "organization_key" => org, "application_key" => app_key }

    if operations.include?("upload")
      file_path = data[:file_path]
      if !File.exist?(file_path)
        Util.exit_with_error("Application file not found: #{file_path} (for #{app_key})")
      end
      entry["original"] = JSON.parse(IO.read(file_path))
    end

    if operations.include?("codegen")
      entry["generators"] = data[:generators]
    end

    entry
  end

  {
    "operations" => operations,
    "applications" => applications,
  }
end

def extract_zip(zip_data, config, project_root)
  require 'tmpdir'

  written = 0
  unchanged = 0

  Dir.mktmpdir("api-batch") do |tmp_dir|
    zip_path = File.join(tmp_dir, "batch.zip")
    IO.binwrite(zip_path, zip_data)

    extract_dir = File.join(tmp_dir, "extracted")
    system("unzip", "-q", zip_path, "-d", extract_dir) || Util.exit_with_error("Failed to unzip #{zip_path}")

    Dir.glob("#{extract_dir}/**/*").each do |full_path|
      next if File.directory?(full_path)

      relative = full_path.sub("#{extract_dir}/", "")
      parts = relative.split("/")
      # Structure: <org_key>/<application_key>/<generator_key>/<files...>
      if parts.length < 4
        Util.warning("Unexpected zip entry: #{relative}")
        next
      end

      _org_key = parts[0]
      application_key = parts[1]
      generator_key = parts[2]
      relative_file = parts[3..].join("/")

      target = config.find_target(application_key, generator_key)
      if target.nil?
        Util.warning("No target found for #{application_key}/#{generator_key}, skipping #{relative}")
        next
      end

      dest_path = File.join(project_root, target, relative_file)
      new_content = IO.read(full_path)

      if File.exist?(dest_path) && !meaningful_change?(new_content, IO.read(dest_path))
        unchanged += 1
      else
        FileUtils.mkdir_p(File.dirname(dest_path))
        IO.binwrite(dest_path, new_content)
        puts "  wrote #{dest_path}"
        written += 1
      end
    end
  end

  puts ""
  puts "  #{written} written, #{unchanged} unchanged"
end

IGNORE_PATTERNS = [
  /^\s*[\*#]\s*Service version:/,
  /^\s*[\*#]\s*User agent:/,
  /^\s*[\*#]\s*apibuilder app/,
].freeze

def meaningful_change?(new_content, existing_content)
  strip_metadata(new_content) != strip_metadata(existing_content)
end

def strip_metadata(content)
  content.each_line.reject { |line| IGNORE_PATTERNS.any? { |p| p.match?(line) } }.join.rstrip
end

# --- Main ---

start_time = Process.clock_gettime(Process::CLOCK_MONOTONIC)

# Handle special subcommands before parse_args (which rejects unknown args)
# Extract --profile early so it works with init/validate too
init_profile = nil
remaining_argv = ARGV.dup
if idx = remaining_argv.index("--profile")
  remaining_argv.delete_at(idx)
  init_profile = remaining_argv.delete_at(idx)
  Util.exit_with_error("--profile requires a value") if init_profile.nil?
end

if remaining_argv.first == "init"
  VALID_LANGUAGES = %w[typescript scala].freeze
  languages = []
  args = remaining_argv[1..].dup
  while arg = args.shift
    case arg
    when "--language"
      lang = args.shift
      Util.exit_with_error("--language requires a value") if lang.nil?
      lang = lang.downcase
      if !VALID_LANGUAGES.include?(lang)
        Util.exit_with_error("Unknown language: #{lang}\nValid languages: #{VALID_LANGUAGES.join(', ')}")
      end
      languages << lang unless languages.include?(lang)
    else
      Util.exit_with_error("Unknown argument: #{arg}\nUsage: api init [--profile PROFILE] [--language typescript] [--language scala]")
    end
  end

  # Resolve api_uri from profile (if config exists), but don't send a token for anonymous init
  api_uri = ApibuilderClient::DEFAULT_API_URI
  global_config_dir = File.join(Dir.home, ".apibuilder")
  global_config_path = File.join(global_config_dir, "config")

  if File.exist?(global_config_path)
    target_section = init_profile ? "profile #{init_profile}" : "default"
    current_section = nil
    IO.readlines(global_config_path).each do |line|
      line = line.strip
      next if line.empty? || line.start_with?("#")
      if md = line.match(/^\[(.+)\]$/)
        current_section = md[1]
      elsif current_section == target_section
        key, value = line.split("=", 2).map(&:strip)
        api_uri = value if key == "api_uri"
      end
    end
  end

  # Create anonymous org without sending auth
  uri = URI.parse("#{api_uri}/apibuilder/anonymous")
  http = Net::HTTP.new(uri.host, uri.port)
  http.use_ssl = uri.scheme == "https"
  http.open_timeout = 30
  http.read_timeout = 60
  req = Net::HTTP::Post.new(uri.request_uri)
  req["Content-Type"] = "application/json"
  response = http.request(req)

  if response.code.to_i != 200 && response.code.to_i != 201
    Util.exit_with_error("Anonymous init failed: HTTP #{response.code}\n#{response.body}")
  end

  result = JSON.parse(response.body)
  org_key = result["organization_key"] or Util.exit_with_error("Server response missing organization_key")
  token = result["token"] or Util.exit_with_error("Server response missing token")

  # Write or update ~/.apibuilder/config
  profile_name = init_profile || "default"
  section_header = init_profile ? "[profile #{init_profile}]" : "[default]"
  section_content = init_profile \
    ? "#{section_header}\napi_uri = #{api_uri}\ntoken = #{token}\n" \
    : "#{section_header}\ntoken = #{token}\n"

  FileUtils.mkdir_p(global_config_dir)

  if File.exist?(global_config_path)
    # Check if this profile section already exists
    existing = IO.read(global_config_path)
    if existing.include?(section_header)
      $stderr.print "Profile '#{profile_name}' already exists in #{global_config_path}. Replace it? [y/N] "
      answer = $stdin.gets&.strip&.downcase
      if answer != "y"
        puts "==> Aborted"
        exit 0
      end
      # Remove existing section (everything from header to next header or EOF)
      lines = existing.lines
      in_section = false
      filtered = lines.reject do |line|
        if line.strip == section_header
          in_section = true
          true
        elsif in_section && line.match?(/^\[/)
          in_section = false
          false
        else
          in_section
        end
      end
      updated = filtered.join.rstrip + "\n\n" + section_content
      tmp_path = "#{global_config_path}.tmp"
      IO.write(tmp_path, updated)
      File.rename(tmp_path, global_config_path)
    else
      # Append new profile section
      IO.write(global_config_path, IO.read(global_config_path).rstrip + "\n\n" + section_content)
    end
  else
    tmp_path = "#{global_config_path}.tmp"
    IO.write(tmp_path, section_content)
    File.rename(tmp_path, global_config_path)
  end

  puts "==> Anonymous org created: #{org_key}"
  puts "==> Token written to #{global_config_path} [#{profile_name}]"

  # Write local .api/config with default generators
  if languages.any?
    local_config_dir = File.join(Dir.pwd, ".api")
    local_config_path = File.join(local_config_dir, "config")
    if File.exist?(local_config_path)
      Util.exit_with_error(".api/config already exists. Delete it first to reinitialize.")
    end

    blocks = []
    if languages.include?("typescript")
      blocks << <<~BLOCK
        - generators:
            typescript: ./src/generated
          applications:
            my-api:
      BLOCK
    end
    if languages.include?("scala")
      blocks << <<~BLOCK
        - generators:
            bryzek_play_model: generated/app/apibuilder
            bryzek_play_mock_model: generated/test/apibuilder
            bryzek_play_client: generated/app/apibuilder
            bryzek_play_mock_client: generated/test/apibuilder
            bryzek_play_controller: generated/app/apibuilder
            bryzek_play_routes: conf
          applications:
            my-api:
      BLOCK
    end

    indented = blocks.map { |b| b.gsub(/^/, "  ") }.join("\n")
    config_content = "#{org_key}:\n#{indented}"

    FileUtils.mkdir_p(local_config_dir)
    tmp_path = "#{local_config_path}.tmp"
    IO.write(tmp_path, config_content)
    File.rename(tmp_path, local_config_path)
    puts "==> .api/config created with #{languages.join(' + ')} generators"
  end

  exit 0
end

if remaining_argv.first == "validate"
  file_path = remaining_argv[1]
  Util.exit_with_error("Usage: api validate <file>") if file_path.nil?
  Util.exit_with_error("File not found: #{file_path}") unless File.exist?(file_path)

  spec = begin
           JSON.parse(IO.read(file_path))
         rescue JSON::ParserError => e
           Util.exit_with_error("Invalid JSON in #{file_path}: #{e.message}")
         end

  client = ApibuilderClient.new(init_profile)
  batch_client = ApiBatchClient.new(client)

  org = spec["organization"]&.[]("key") || "tmp"
  app = spec["application"]&.[]("key") || File.basename(file_path, ".json")

  form = {
    "operations" => ["upload"],
    "applications" => [
      {
        "organization_key" => org,
        "application_key"  => app,
        "original"         => spec,
      }
    ],
  }

  begin
    batch = batch_client.create_batch(org, form)
    batch_id = batch["id"]
    result = batch_client.poll_until_complete(org, batch_id)

    case result["status"]
    when "done"
      puts "==> #{file_path}: valid"
      exit 0
    when "error"
      errors = result["errors"] || []
      $stderr.puts "==> #{file_path}: validation failed"
      errors.each { |e| $stderr.puts "  - #{e["message"]}" }
      exit 1
    else
      Util.exit_with_error("Unexpected batch status '#{result["status"]}' for #{file_path}")
    end
  rescue ApibuilderClient::Error => e
    $stderr.puts "==> #{file_path}: validation failed"
    $stderr.puts "  #{e.message}"
    exit 1
  end
end

parsed = parse_args(ARGV)
profile = parsed[:profile]
operations = parsed[:operations]
app_filter = parsed[:apps]
group_filter = parsed[:group]

config_path = File.join(`pwd`.strip, ".api", "config")
config = ApiConfig.new(config_path)

if operations.empty?
  operations = ["codegen"]
  has_specs = config.blocks.any? { |b| b.applications.any? { |a| File.exist?(a.file_path) } }
  if has_specs
    operations.unshift("upload")
  end
  puts "==> Auto-detected operations: #{operations.join(', ')}"
end

client = ApibuilderClient.new(profile)
batch_client = ApiBatchClient.new(client)
project_root = `pwd`.strip

if group_filter
  all_groups = config.blocks.map(&:group).compact.uniq
  if !all_groups.include?(group_filter)
    Util.exit_with_error("Unknown group: #{group_filter}\n  Available: #{all_groups.sort.join(', ')}")
  end
end

if app_filter
  filtered_blocks = group_filter ? config.blocks.select { |b| b.group == group_filter } : config.blocks
  all_app_keys = filtered_blocks.flat_map { |b| b.applications.map(&:key) }.uniq
  missing = app_filter.select { |a| !all_app_keys.include?(a) }
  if missing.any?
    msg = "Unknown app(s): #{missing.join(', ')}\n  Available: #{all_app_keys.sort.join(', ')}"
    Util.exit_with_error(msg)
  end
end

num_orgs = config.orgs.size
puts "==> Processing #{num_orgs} #{num_orgs == 1 ? 'organization' : 'organizations'}"

config.orgs.each do |org|
  puts "==> Building batch for #{org}"
  form = build_batch_form(config, org, operations, app_filter, group_filter)

  if form["applications"].empty?
    next
  end

  num_apps = form["applications"].size
  puts "==> Submitting batch to #{org} (#{num_apps} #{num_apps == 1 ? 'application' : 'applications'}, operations: #{operations.join(', ')})"
  batch = batch_client.create_batch(org, form)
  batch_id = batch["id"]
  puts "==> Batch #{batch_id} created, polling for completion..."

  result = batch_client.poll_until_complete(org, batch_id)

  case result["status"]
  when "error"
    $stderr.puts ""
    $stderr.puts "=" * 60
    errors = result["errors"] || []
    $stderr.puts "Batch failed with #{errors.size} error(s):"
    errors.each do |err|
      parts = [err["application_key"], err["generator_key"]].compact.join("/")
      $stderr.puts "  - #{parts}: #{err["message"]}"
    end
    $stderr.puts "=" * 60
    exit 1
  when "done"
    puts "==> Batch #{batch_id} completed"

    if operations.include?("codegen")
      if result["zip_file"].nil?
        $stderr.puts "WARNING: Batch completed but no zip_file in response. Full result: #{JSON.generate(result.reject { |k,_| k == "applications" })}"
      end
    end

    if operations.include?("codegen") && result["zip_file"]
      zip_url = result["zip_file"]["url"]
      puts "==> Downloading generated code..."
      zip_data = batch_client.download_zip(zip_url)
      if zip_data.nil?
        Util.exit_with_error("Batch completed but zip has expired. Please re-run.")
      end
      puts "==> Extracting files..."
      extract_zip(zip_data, config, project_root)
    end
  end
end

elapsed = Process.clock_gettime(Process::CLOCK_MONOTONIC) - start_time
puts "==> Done (#{format('%.1f', elapsed)} seconds)"
