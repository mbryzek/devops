#!/usr/bin/env ruby

# Uploads all API JSON files to API Builder and downloads generated code.
#
# Usage:
#   apibuilder_apps                              # Upload and download all specs
#   apibuilder_apps --app platform --app hoa-api # Specific apps only
#   apibuilder_apps --profile new                # Use specific profile
#   apibuilder_apps --no_download                # Upload only
#   apibuilder_apps --dir examples               # Specs from different directory
#   apibuilder_apps --tag 0.0.2-dev              # Specific version tag

load File.join(File.dirname(__FILE__), '../lib/common.rb')

args = Args.parse(ARGV, [], { "app" => "list" })

Util.assert_installed("sem-info", "https://github.com/mbryzek/schema-evolution-manager")

organization = DevopsConfigFile.load.apibuilder_organization
client = ApibuilderClient.new(args.profile)

def calculate_next_tag
  `sem-info tag next micro`.strip
end

# Resolves dependencies of the specifications, returning the specs in
# an order in which their internal dependencies will resolve.
def resolve_dependencies(remaining, ordered=[])
  if next_spec = remaining.find { |spec| resolved?(ordered, spec) }
    resolve_dependencies(remaining - [next_spec], ordered + [next_spec])
  else
    ordered + remaining
  end
end

def resolved?(specs, spec)
  spec.dependencies.all? { |dep|
    specs.find { |s|
      s.organization == dep.organization && s.application == dep.application
    }
  }
end

tag = args.tag || begin
  `git fetch --tags origin 2>/dev/null`
  calculate_next_tag
end
spec_dir = args.dir || Pathname.new(File.join(`pwd`.strip, "spec")).cleanpath
if !File.directory?(spec_dir)
  Util.exit_with_error "Cannot find directory containing specs. Expected at: #{spec_dir}"
end

class Dependency
  attr_reader :organization, :application
  def initialize(organization, application)
    @organization = organization
    @application = application
  end

  def Dependency.from_uri(uri)
    if md = uri.match(/^https?:\/\/(?:app|www)\.apibuilder\.io\/([^\/]+)\/([^\/]+)/)
      Dependency.new(md[1], md[2])
    else
      Util.exit_with_error("Could not parse import uri[%s]" % uri)
    end
  end
end

class Spec
  attr_reader :organization, :application, :path, :dependencies

  def initialize(organization, application, path)
    @organization = organization
    @application = application
    @path = path
    @dependencies = parse_dependencies
  end

  private

  def parse_dependencies
    contents = IO.read(@path)
    json = begin
             JSON.parse(contents)
           rescue JSON::ParserError
             puts "** WARNING: File is not valid json: %s" % @path
             {}
           end
    (json['imports'] || []).map { |imp| Dependency.from_uri(imp['uri']) }
  end
end

def validate_versions_not_ahead(client, specs, upload_version)
  specs.each do |spec|
    latest = nil #client.get_latest_version(spec.organization, spec.application)
    next if latest.nil?

    remote_version = latest["version"]
    next if remote_version.nil? || remote_version.empty?

    if Gem::Version.new(remote_version) > Gem::Version.new(upload_version)
      puts "** ERROR: API has version #{remote_version} for #{spec.organization}/#{spec.application}"
      puts "   but we are trying to upload #{upload_version} (from git tags)."
      puts "   This means someone uploaded a higher version directly."
      puts ""
      puts "   To fix: investigate who uploaded #{remote_version}, then either"
      puts "   create a git tag to match, or remove the stale remote version."
      exit(1)
    end
  end
end

def download_code(client, app_config, specs, tag, errors)
  Dir.mktmpdir("apibuilder") do |tmp_dir|
    # Collect all (spec, generator) work items
    work_items = []
    specs.each do |spec|
      entries = app_config.find_by_app(spec.application)
      entries.each do |entry|
        entry.generators.each do |gen|
          work_items << { spec: spec, gen: gen }
        end
      end
    end

    # Download in parallel batches, stage to temp dir
    mutex = Mutex.new
    staged = []
    work_items.each_slice(client.max_threads) do |batch|
      threads = batch.map do |item|
        Thread.new do
          spec = item[:spec]
          gen = item[:gen]
          puts "==> Downloading #{spec.organization}/#{spec.application}@#{tag} #{gen.key} => #{gen.target}"
          attrs = gen.attributes.empty? ? nil : gen.attributes
          begin
            code = client.get_code(spec.organization, spec.application, tag, gen.key, attrs)
            pairs = ApibuilderFileWriter.stage_code_files(code, gen.target, tmp_dir)
            mutex.synchronize { staged.concat(pairs) }
          rescue ApibuilderClient::Error => e
            mutex.synchronize { errors << e.message }
            $stderr.puts "ERROR: #{e.message}"
          end
        end
      end
      threads.each(&:join)
    end

    puts "==> Writing #{staged.size} files"
    ApibuilderFileWriter.flush(staged)
  end
end

specs = Dir.glob("#{spec_dir}/*.json").map do |path|
  name = File.basename(path).sub(/\.json$/, '')
  Spec.new(organization, name, path)
end

ordered = resolve_dependencies(specs.sort_by { |s| [s.organization, s.application] })
filtered = args.app.nil? ? ordered : ordered.select { |spec| args.app.include?(spec.application) }

if args.app && filtered.size != args.app.size
  missing = args.app.select { |n| !filtered.map(&:application).include?(n) }
  msg = missing.size == 1 ? "** ERROR: Did not find spec: %s\n" : "** ERROR: Did not find specs: %s\n"
  msg = msg % missing.join(", ")
  msg << "  Available specs:\n"
  msg << "    " + specs.map(&:application).join("\n    ")
  Util.exit_with_error msg
end

validate_versions_not_ahead(client, filtered, tag)

errors = []

# Upload
uploaded = []
filtered.each do |spec|
  puts "==> Uploading #{spec.organization}/#{spec.application}@#{tag}"
  begin
    client.upload_version(spec.organization, spec.application, tag, spec.path)
    uploaded << spec
  rescue ApibuilderClient::Error => e
    errors << e.message
    $stderr.puts "ERROR: #{e.message}"
  end
end

# Download (only specs that uploaded successfully)
if !args.no_download
  app_config_path = File.join(`pwd`.strip, ".apibuilder", "config")
  if File.exist?(app_config_path)
    app_config = ApibuilderAppConfig.new(app_config_path)
    download_code(client, app_config, uploaded, tag, errors)
  else
    puts "** No .apibuilder/config found, skipping download"
  end
end

if errors.any?
  $stderr.puts ""
  $stderr.puts "=" * 60
  $stderr.puts "#{errors.size} error(s):"
  errors.each { |e| $stderr.puts "  - #{e}" }
  $stderr.puts "=" * 60
  exit 1
end
