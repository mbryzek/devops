#!/usr/bin/env ruby

# Releases a Scala application to Kubernetes.
# Builds Docker image and deploys to K8s cluster.
#
# Usage: release-scala --app <app_name>

require_relative '../lib/common'

args = Args.parse(ARGV, ["app"])
app = args.app

# Get version tag
version = Tag.ask

puts ""
puts Util.underline("Releasing #{app} version #{version}")
puts ""

# Write conf/version.txt so the deployed app can serve /_internal_/version
set_version_cmd = File.expand_path("~/code/claude/bin/set-version") +
  " --app #{app} --version #{version}"
Util.run(set_version_cmd)

# Build Docker image
puts "Building Docker image..."
build_cmd = File.join(__dir__, "k8s-build") + " --app #{app} --tag #{version}"
Util.run(build_cmd)

puts ""

# Sync ConfigMap + Secrets so the new pods load current env values.
# release-scala used to skip this, which left stale config in the cluster.
puts "Syncing ConfigMap + Secrets..."
secrets_cmd = File.join(__dir__, "k8s-secrets") + " --app #{app}"
Util.run(secrets_cmd)

puts ""

# Deploy to Kubernetes
puts "Deploying to Kubernetes..."
deploy_cmd = File.join(__dir__, "k8s-deploy") + " --app #{app} --tag #{version}"
Util.run(deploy_cmd)

puts ""
puts "Release complete: #{app} #{version}"
puts ""
