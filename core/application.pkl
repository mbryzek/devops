open module Application

class Application {
    name: String(!isEmpty)
    port: Int(isBetween(0, 100000))
    scala: ScalaConfig?
    elm: ElmConfig?
    sveltekit: SvelteKit?
    docker_k8s: DockerK8sConfig?

    /// Source of the production domain for version-check pings. Set exactly one
    /// of `platform_tenant_id` or `prod_domain` for deployable apps; leave both
    /// null for non-deployable apps (archived projects, k8s workers that don't
    /// expose an HTTP /version, etc.).
    platform_tenant_id: String?
    prod_domain: String?

    /// GitHub repository in "owner/name" form. Null = derive from `name`.
    repo: String?

    /// Mark a project as ignored — excluded from version checks and deploy
    /// tracking even if it has a tenant id or prod_domain set. Use for archived
    /// or non-HTTP-deployable apps.
    ignored: Boolean = false
}

class SvelteKit {}

/// Release config for hand-written-manifest k8s apps built as a Docker image
/// (e.g. workers). Released via `release-docker-k8s` which:
///   1. tags via `Tag.ask`
///   2. runs <source_dir>/<build_script> to build + push the image
///   3. applies every manifest under <manifests_dir>, sed-substituting
///      `__IMAGE_TAG__` with the new tag
///   4. waits on `kubectl rollout status <rollout_target>` in <namespace>
class DockerK8sConfig {
    /// Path (relative to source dir) to the build-and-push script. The script
    /// must accept the tag as its first positional argument.
    build_script: String = "bin/build-and-push.sh"
    /// Directory containing k8s manifests, relative to the devops repo root.
    /// Every *.yaml is `kubectl apply`d with __IMAGE_TAG__ substituted.
    manifests_dir: String
    /// Resource to wait on, e.g. "statefulset/workers".
    rollout_target: String
    /// Kubernetes namespace.
    namespace: String = "bryzek-production"
}

class ElmConfig {
    rewrites: Listing<ElmRewrite>?
}

class ElmRewrite {
    from: String
    to: String
}

class ScalaConfig {
    production : ScalaEnvironment
    development : ScalaEnvironment
}

class ScalaEnvironment {
    database: Database
}

class Database {
    name: String(!isEmpty)
    host: String(!isEmpty)
    user: String(!isEmpty)
    port: Int
}
