/// Shared schema for `.api/config.pkl` files consumed by the `api` CLI.
///
/// Usage in a project's `.api/config.pkl`:
///
///     amends "modulepath:/api_config.pkl"
///
///     org = "bryzek"
///     blocks {
///       new PlayFullStack { subproject = "api"; applications { "platform" } }
///       new TypeScript { applications { "platform-error" } }
///       new TypeScriptFiles {}       // platform-storage with filter.types=[file]
///       new Elm { applications { "acumen-api" } }
///       new Dao {}
///     }
///
/// The `api` CLI invokes `pkl eval` with `--module-path <devops>/core` so that
/// `modulepath:/api_config.pkl` resolves to this file.

@ModuleInfo { minPklVersion = "0.27.0" }
open module ApiConfig

/// Base class for an apibuilder config block: one set of generators applied
/// to a list of applications. Use a subclass when one matches; otherwise
/// instantiate `Block` directly with an explicit generators map.
open class Block {
  generators: Mapping<String, String>
  applications: Listing<String> = new Listing {}
  attributes: Mapping<String, Any>? = null
  group: String? = null
  spec_glob: String? = null
}

// === Scala Play generators ===

/// Play subproject codegen: controller + client + mock client + routes.
/// `bryzek_play_routes` targets `<subproject>/conf` in the project root.
class PlayFullStack extends Block {
  hidden subproject: String

  generators = new Mapping {
    ["bryzek_play_controller"] = "generated/app/apibuilder"
    ["bryzek_play_client"] = "generated/app/apibuilder"
    ["bryzek_play_mock_client"] = "generated/test/apibuilder"
    ["bryzek_play_routes"] = "\(subproject)/conf"
  }
}

/// Model + mock model only. No client, controller, or routes.
class PlayModel extends Block {
  generators = new Mapping {
    ["bryzek_play_model"] = "generated/app/apibuilder"
    ["bryzek_play_mock_model"] = "generated/test/apibuilder"
  }
}

/// Client + mock client only. Defaults match standard Play layout; override
/// `client_target` / `mock_target` for libraries with custom paths.
class PlayClient extends Block {
  hidden client_target: String = "generated/app/apibuilder"
  hidden mock_target: String = "generated/test/apibuilder"

  generators = new Mapping {
    ["bryzek_play_client"] = client_target
    ["bryzek_play_mock_client"] = mock_target
  }
}

/// DAO code generation driven by `dao/spec/*.json`.
class Dao extends Block {
  group = "dao"
  spec_glob = "dao/spec/*.json"
  generators = new Mapping {
    ["psql_scala"] = "generated/app"
    ["psql_ddl"] = "dao/psql"
  }
}

// === Frontend generators ===

/// TypeScript client codegen. Default target is `./src/generated`; override
/// `target` for projects that place generated code elsewhere (e.g. playwright
/// subprojects often use `./generated`).
open class TypeScript extends Block {
  hidden target: String = "./src/generated"

  generators = new Mapping {
    ["typescript"] = target
  }
}

/// TypeScript codegen for `platform-storage` with `filter.types=[file]`.
/// This exact pattern appears in every frontend project that uploads files.
class TypeScriptFiles extends TypeScript {
  attributes = new Mapping {
    ["filter"] = new Mapping {
      ["types"] = new Listing { "file" }
    }
  }
  applications = new Listing { "platform-storage" }
}

/// Elm v2 client codegen. Default target is `./src`.
class Elm extends Block {
  hidden target: String = "./src"

  generators = new Mapping {
    ["elm_v2"] = target
  }
}

// === Output ===

/// The apibuilder organization key (e.g. "bryzek").
org: String

/// Explicit blocks. Use for anything that doesn't fit the `subprojects`
/// shortcut below (PlayModel, PlayClient, Dao, TypeScript, Elm, etc.).
blocks: Listing<Block> = new Listing {}

/// Shortcut for PlayFullStack blocks: one entry per Play subproject ->
/// list of applications. Each entry expands to a PlayFullStack block
/// with routes -> `<subproject>/conf`. Usage:
///
///     subprojects {
///       api { "platform"; "platform-cluster" }
///       hoa { "hoa-api"; "hoa-admin" }
///     }
subprojects: Dynamic = new Dynamic {}

local allBlocks: Listing<Block> = new Listing {
  for (b in blocks) { b }
  for (sp, apps in subprojects.toMap()) {
    new PlayFullStack {
      subproject = sp as String
      applications = new Listing<String> { for (a in apps as Dynamic) { a as String } }
    }
  }
}

output {
  value = new Mapping { [org] = allBlocks }
  renderer = new YamlRenderer {}
}
